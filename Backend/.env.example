NODE_ENV=development
PORT=4000


DATABASE_URL=postgres://postgres:root@localhost:5432/dental_dashboard
PGSSLMODE=disable


JWT_ACCESS_SECRET=replace_with_strong_random_64+_chars
JWT_REFRESH_SECRET=replace_with_strong_random_64+_chars
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# Used to encrypt medical records (32 bytes as base64 for AES-256-GCM)
MEDICAL_RECORD_ENC_KEY_B64=replace_with_32_bytes_base64

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100


UPLOAD_MAX_MB=5

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
