              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/patients/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["patients", "{{patientId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+1-555-0101\",\n  \"medical_history\": \"Asthma, penicillin allergy (updated)\"\n}"
            }
          }
        },
        {
          "name": "Delete Patient (soft delete)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/patients/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["patients", "{{patientId}}"] }
          }
