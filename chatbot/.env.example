# Same values as your Backend/.env — copy them here
DATABASE_URL=postgres://postgres:root@localhost:5432/dental_dashboard
PGSSLMODE=disable

# Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Must match Backend MEDICAL_RECORD_ENC_KEY_B64 exactly (same key decrypts fields)
MEDICAL_RECORD_ENC_KEY_B64=replace_with_32_bytes_base64

# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:4000
